{
  "schemaVersion": 1,
  "id": "rankboard",
  "version": "${version}",
  "name": "RankBoard",
  "description": "Server-side vanilla-stat leaderboards with rolling daily, weekly, monthly, yearly, and all-time periods.",
  "environment": "*",
  "entrypoints": {
    "main": ["cn.bamgdam.rankboard.RankBoardMod"]
  },
  "mixins": [
    {
      "config": "rankboard.mixins.json",
      "environment": "server"
    }
  ],
  "depends": {
    "fabricloader": ">=${minimum_loader_version}",
    "minecraft": "${minecraft_version}",
    "java": ">=${minimum_java_version}",
    "fabric-api": "*"
  }
}
